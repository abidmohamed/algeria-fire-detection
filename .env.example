# NASA FIRMS API Configuration
NASA_FIRMS_KEY=your_firms_map_key_here

# Telegram Alert Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=@your_channel_or_group_id

# Copernicus Data Space Ecosystem (CDSE) Credentials
CDSE_USERNAME=your_cdse_username_here
CDSE_PASSWORD=your_cdse_password_here

# Supabase PostgreSQL Connection String
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
